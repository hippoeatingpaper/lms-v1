# ============================================================
# 수업 관리 시스템 — 환경 변수 설정
# ============================================================
# 이 파일을 복사하여 .env로 저장한 뒤, 값을 수정하세요.
# cp .env.example .env  (Linux/Mac)
# copy .env.example .env  (Windows)
# ============================================================

# ─────────────────────────────────────────────
# 서버 설정
# ─────────────────────────────────────────────

# 서버 포트 (기본값: 3000)
PORT=3000

# 실행 환경: development | production
NODE_ENV=development

# 교사 노트북 IP 주소 (ipconfig 또는 ifconfig로 확인)
# CORS 허용 오리진 및 인증서 생성에 사용됩니다.
# 예: 192.168.1.100
SERVER_IP=192.168.1.100

# ─────────────────────────────────────────────
# HTTPS 설정 (세션 스니핑 방지)
# ─────────────────────────────────────────────

# HTTPS 활성화 여부 (프로덕션에서는 true 권장)
# 인증서 생성: node scripts/generateCert.js
HTTPS_ENABLED=true

# 인증서 저장 경로 (기본값: ./certs)
# CERT_DIR=./certs

# ─────────────────────────────────────────────
# 데이터베이스
# ─────────────────────────────────────────────

# SQLite 데이터베이스 파일 경로
DB_PATH=./data/database.db

# ─────────────────────────────────────────────
# 인증 (JWT)
# ─────────────────────────────────────────────

# ⚠️ 반드시 변경하세요! 최소 32자 이상의 랜덤 문자열
# 생성 방법: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=여기에_최소_32자_이상의_랜덤_문자열_입력

# Access Token 만료 시간 (기본값: 3h)
JWT_ACCESS_EXPIRES=3h

# Refresh Token 만료 시간 (기본값: 7d)
JWT_REFRESH_EXPIRES=7d

# ─────────────────────────────────────────────
# 파일 업로드
# ─────────────────────────────────────────────

# 업로드 파일 저장 경로
UPLOAD_DIR=./uploads

# 일반 파일 최대 크기 (bytes) — 기본값: 20MB
MAX_FILE_SIZE=20971520

# 동영상(.mp4) 최대 크기 (bytes) — 기본값: 100MB
# ⚠️ 300MB에서 100MB로 하향 (저사양 스마트폰 메모리 부족 방지)
MAX_VIDEO_SIZE=104857600

# ─────────────────────────────────────────────
# 백업
# ─────────────────────────────────────────────

# ⚠️ 반드시 변경하세요! 백업 파일 암호화 비밀번호
# 이 비밀번호를 잊으면 백업 파일을 복원할 수 없습니다.
BACKUP_PASSWORD=여기에_강력한_백업_비밀번호_입력

# ─────────────────────────────────────────────
# 개발 환경 전용 (선택사항)
# ─────────────────────────────────────────────

# Vite 개발 서버 포트 (기본값: 5173)
# VITE_PORT=5173

# 디버그 로깅 활성화
# DEBUG=true
